# UX Audit Admin - Environment Configuration
# Copy this file to .env and fill in the values

# Supabase Configuration
# The URL is already configured in the app for the shared database
SUPABASE_URL=https://kkpvlpbfslxkutunbigi.supabase.co

# SUPABASE_ANON_KEY - Public key (safe to share, limited permissions)
# Get this from your Supabase Dashboard → Project Settings → API
SUPABASE_ANON_KEY=your_anon_key_here

# SUPABASE_SERVICE_KEY - Secret key (full admin access, keep private!)
# This is needed for storage uploads and full database access
# Get this from your Supabase Dashboard → Project Settings → API → service_role key
SUPABASE_SERVICE_KEY=your_service_role_key_here

# Optional: Anthropic API Key for AI analysis features
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_key_here
